---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div
  class="bg-bg-panel border border-border-subtle rounded-lg p-6 hover:border-border-hover transition-colors"
>
  <div
    class="w-8 h-8 flex items-center justify-center bg-bg-input border border-border-subtle rounded-md mb-4"
  >
    <slot name="icon" />
  </div>
  <h3 class="text-base font-medium mb-2">{title}</h3>
  <p class="text-sm text-text-secondary">{description}</p>
</div>
