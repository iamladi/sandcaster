---
import { getDocsNavigation } from "../lib/navigation";

interface Props {
  currentId: string;
}

const { currentId } = Astro.props;
const sections = getDocsNavigation();
---

<!-- Mobile docs nav toggle -->
<div class="lg:hidden mb-6">
  <button
    id="docs-nav-toggle"
    type="button"
    class="flex items-center gap-2 px-4 py-2 w-full text-sm text-text-secondary border border-border-subtle rounded-lg hover:border-border-hover transition-colors"
    aria-expanded="false"
    aria-controls="docs-nav-mobile"
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M3 12h18M3 6h18M3 18h18"></path>
    </svg>
    <span>Documentation Menu</span>
    <svg
      id="docs-nav-chevron"
      class="ml-auto transition-transform"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </button>
  <nav
    id="docs-nav-mobile"
    class="hidden mt-2 border border-border-subtle rounded-lg p-4 bg-bg-panel"
    aria-label="Documentation"
  >
    {
      sections.map((section, sectionIndex) => (
        <div>
          <p
            class={`text-xs uppercase text-text-tertiary tracking-wider mb-2 ${sectionIndex === 0 ? "mt-0" : "mt-4"}`}
          >
            {section.title}
          </p>
          <ul>
            {section.items.map((item) => (
              <li>
                <a
                  href={`/docs/${item.id}`}
                  class={`block py-1.5 text-sm transition-colors ${
                    item.id === currentId
                      ? "text-accent"
                      : "text-text-secondary hover:text-text-primary"
                  }`}
                  aria-current={item.id === currentId ? "page" : undefined}
                >
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</div>

<!-- Desktop sidebar -->
<nav
  class="w-64 shrink-0 hidden lg:block sticky top-20 self-start overflow-y-auto max-h-[calc(100vh-5rem)]"
  aria-label="Documentation"
>
  {
    sections.map((section, sectionIndex) => (
      <div>
        <p
          class={`text-xs uppercase text-text-tertiary tracking-wider mb-2 ${sectionIndex === 0 ? "mt-0" : "mt-6"}`}
        >
          {section.title}
        </p>
        <ul>
          {section.items.map((item) => (
            <li>
              <a
                href={`/docs/${item.id}`}
                class={`block py-1 text-sm transition-colors ${
                  item.id === currentId
                    ? "text-accent"
                    : "text-text-secondary hover:text-text-primary"
                }`}
                aria-current={item.id === currentId ? "page" : undefined}
              >
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</nav>

<script>
  const toggle = document.getElementById("docs-nav-toggle");
  const nav = document.getElementById("docs-nav-mobile");
  const chevron = document.getElementById("docs-nav-chevron");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("hidden");
    chevron?.classList.toggle("rotate-180");
  });
</script>
