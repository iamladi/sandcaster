---
import { getDocsNavigation } from "../lib/navigation";

interface Props {
	currentId: string;
}

const { currentId } = Astro.props;
const sections = getDocsNavigation();
---

<nav
	class="w-64 shrink-0 hidden lg:block sticky top-20 self-start overflow-y-auto max-h-[calc(100vh-5rem)]"
>
	{
		sections.map((section, sectionIndex) => (
			<div>
				<p
					class={`text-xs uppercase text-text-tertiary tracking-wider mb-2 ${sectionIndex === 0 ? "mt-0" : "mt-6"}`}
				>
					{section.title}
				</p>
				<ul>
					{section.items.map((item) => (
						<li>
							<a
								href={`/docs/${item.id}`}
								class={`block py-1 text-sm transition-colors ${
									item.id === currentId
										? "text-accent"
										: "text-text-secondary hover:text-text-primary"
								}`}
							>
								{item.title}
							</a>
						</li>
					))}
				</ul>
			</div>
		))
	}
</nav>
