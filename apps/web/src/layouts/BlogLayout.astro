---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  tags?: string[];
}

const { title, description, date, author, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <main class="max-w-3xl mx-auto px-8 py-12">
    <header>
      <h1 class="text-3xl font-medium">{title}</h1>
      <div class="flex items-center gap-3 mt-2">
        <time class="text-sm text-text-tertiary">{formattedDate}</time>
        {author && <span class="text-sm text-text-tertiary">by {author}</span>}
      </div>
      {
        tags && tags.length > 0 && (
          <div class="flex gap-2 mt-3 flex-wrap">
            {tags.map((tag) => (
              <span class="inline-flex px-2 py-0.5 rounded-full border border-border-subtle text-xs text-text-secondary">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <div class="border-b border-border-subtle my-8"></div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <div class="mt-12">
      <a
        href="/blog"
        class="text-sm text-text-secondary hover:text-text-primary transition"
        >&larr; Back to Blog</a
      >
    </div>
  </main>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: 0.5rem;
  }

  .prose h3 {
    font-size: 1.125rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }

  .prose p {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.625;
  }

  .prose code {
    background-color: var(--color-bg-panel);
    padding-left: 0.375rem;
    padding-right: 0.375rem;
    padding-top: 0.125rem;
    padding-bottom: 0.125rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-accent);
    font-family: ui-monospace, monospace;
  }

  .prose pre {
    background-color: var(--color-bg-panel);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.375rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.875rem;
  }

  .prose pre code {
    background-color: transparent;
    padding-left: 0;
    padding-right: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  .prose a {
    color: var(--color-accent);
  }

  .prose a:hover {
    text-decoration: underline;
  }

  .prose ul {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }

  .prose ol {
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: decimal;
  }

  .prose li {
    margin-bottom: 0.5rem;
  }

  .prose table {
    width: 100%;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .prose th {
    text-align: left;
    color: var(--color-text-primary);
    font-weight: 500;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .prose td {
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border-subtle);
    padding-left: 0.75rem;
    padding-right: 0.75rem;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
