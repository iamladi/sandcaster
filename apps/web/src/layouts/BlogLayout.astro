---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  tags?: string[];
}

const { title, description, date, author, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<BaseLayout title={title} description={description}>
  <main class="max-w-3xl mx-auto px-8 py-12">
    <header>
      <h1 class="text-3xl font-medium">{title}</h1>
      <div class="flex items-center gap-3 mt-2">
        <time class="text-sm text-text-tertiary">{formattedDate}</time>
        {author && <span class="text-sm text-text-tertiary">by {author}</span>}
      </div>
      {
        tags && tags.length > 0 && (
          <div class="flex gap-2 mt-3 flex-wrap">
            {tags.map((tag) => (
              <span class="inline-flex px-2 py-0.5 rounded-full border border-border-subtle text-xs text-text-secondary">
                {tag}
              </span>
            ))}
          </div>
        )
      }
      <div class="border-b border-border-subtle my-8"></div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <div class="mt-12">
      <a
        href="/blog"
        class="text-sm text-text-secondary hover:text-text-primary transition"
        >&larr; Back to Blog</a
      >
    </div>
  </main>
</BaseLayout>
