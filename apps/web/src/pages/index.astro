---
import BaseLayout from "../layouts/BaseLayout.astro";
import Badge from "../components/Badge.astro";
import Button from "../components/Button.astro";
import IDEPanel from "../components/IDEPanel.astro";
import FeatureCard from "../components/FeatureCard.astro";
import TerminalBlock from "../components/TerminalBlock.astro";
import StarterBadges from "../components/StarterBadges.astro";
---

<BaseLayout
	title="Sandcaster"
	description="An open-source TypeScript runtime for AI agents in isolated sandboxes. CLI, API, SDK, and Slack with streaming, file uploads, and config-driven behavior."
>
	<main class="max-w-[1200px] mx-auto px-8 w-full">
		<!-- Hero -->
		<section class="py-24 grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-16 items-center">
			<div>
				<Badge class="mb-8">
					<span class="text-text-primary flex items-center">
						<svg
							width="12"
							height="12"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							aria-hidden="true"
						>
							<path d="M5 12h14M12 5l7 7-7 7"></path>
						</svg>
					</span>
					<span>v0.1.0 Released</span>
					<span class="text-text-primary">— Streaming API</span>
				</Badge>
				<h1
					class="text-4xl md:text-5xl lg:text-[3.5rem] font-medium leading-[1.1] tracking-tight mb-6"
				>
					Ship <span class="text-accent">AI Agents</span><br />With Confidence.
				</h1>
				<p class="text-lg text-text-secondary mb-10 max-w-[90%]">
					An open-source TypeScript runtime designed for production. Isolated
					sandboxes, multi-turn orchestration, and streaming capabilities out of
					the box. Positioned perfectly between raw LLM SDKs and bloated
					frameworks.
				</p>
				<div class="flex gap-4 flex-wrap">
					<Button href="/docs/getting-started">Get Started</Button>
					<Button variant="secondary" href="/docs">Read Docs</Button>
				</div>
			</div>

			<div class="hidden lg:block">
				<IDEPanel />
			</div>
		</section>

		<!-- Features -->
		<section class="py-16 border-t border-border-subtle">
			<div class="text-center mb-12">
				<h2 class="text-2xl md:text-3xl font-medium mb-4">
					Everything You Need to Ship Agents
				</h2>
				<p class="text-text-secondary max-w-[600px] mx-auto">
					From sandbox isolation to multi-agent orchestration, Sandcaster
					handles the infrastructure so you can focus on your agent's logic.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				<FeatureCard
					title="Isolated Execution"
					description="Run untrusted AI code securely. Built-in adapters for E2B, Docker, Vercel, and Cloudflare for fresh sandboxes per run."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="9" y1="3" x2="9" y2="21"></line>
					</svg>
				</FeatureCard>

				<FeatureCard
					title="Streaming API (SSE)"
					description="Native Server-Sent Events support. Stream tokens, tool calls, and state changes to the client with zero latency overhead."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<circle cx="12" cy="12" r="10"></circle>
						<path d="M12 8v4l3 3"></path>
					</svg>
				</FeatureCard>

				<FeatureCard
					title="Speculative Branching"
					description="Fork agent states safely. Test different tool paths simultaneously and merge the most successful result back to main."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<path d="M6 3v12"></path>
						<circle cx="18" cy="6" r="3"></circle>
						<circle cx="6" cy="18" r="3"></circle>
						<path d="M18 9a9 9 0 0 1-9 9"></path>
					</svg>
				</FeatureCard>

				<FeatureCard
					title="Multi-Agent Orchestration"
					description="Define supervisor agents that delegate tasks to specialized sub-agents with strict type-checked communication channels."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
				</FeatureCard>

				<FeatureCard
					title="Multiple Interfaces"
					description="Don't just build APIs. Sandcaster ships with ready-to-use hooks for CLI, TUI, HTTP APIs, and native Slack bot integration."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="3" y1="9" x2="21" y2="9"></line>
						<line x1="9" y1="21" x2="9" y2="9"></line>
					</svg>
				</FeatureCard>

				<FeatureCard
					title="Config-Driven via JSON"
					description="Manage environments, model selection, and telemetry settings globally using a simple sandcaster.json configuration file."
				>
					<svg
						slot="icon"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<path
							d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
						></path>
						<polyline points="14 2 14 8 20 8"></polyline>
						<line x1="16" y1="13" x2="8" y2="13"></line>
						<line x1="16" y1="17" x2="8" y2="17"></line>
						<polyline points="10 9 9 9 8 9"></polyline>
					</svg>
				</FeatureCard>
			</div>
		</section>

		<!-- Terminal + Starters -->
		<section
			class="py-16 border-t border-border-subtle grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
		>
			<div>
				<h2 class="text-2xl md:text-3xl font-medium mb-4">
					Built for the Terminal & Beyond.
				</h2>
				<p class="text-text-secondary mb-8">
					Sandcaster's core philosophy is decoupling logic from the interface.
					Build your agent once, deploy it as a script, a persistent API, or an
					interactive terminal application.
				</p>
				<StarterBadges />
			</div>

			<TerminalBlock>
				<div class="mb-2">
					<span class="text-syntax-function">$</span> sandcaster init
					--template research-brief
				</div>
				<div class="text-text-tertiary mb-2">
					Initializing workspace...<br />
					Installing dependencies...<br />
					Generating sandcaster.json...
				</div>
				<div class="mb-2">
					<span class="text-syntax-string">Success!</span> Run `sandcaster dev`
					to start the TUI.
				</div>
				<div>
					<span class="text-syntax-function">$</span> sandcaster dev
				</div>
				<div class="mt-4 text-accent">
					[Sandcaster Runtime] Ready. Agent 'Researcher' listening on stdio.
				</div>
			</TerminalBlock>
		</section>
	</main>
</BaseLayout>
