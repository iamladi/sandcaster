# Required for all E2B examples (01-06, 10-14)
E2B_API_KEY=your-e2b-key          # https://e2b.dev/dashboard

# Required for all examples using gpt5mini (default model)
OPENAI_API_KEY=your-openai-key    # https://platform.openai.com/api-keys

# Provider-specific (only needed for provider examples)
VERCEL_TOKEN=your-vercel-token                          # 07-provider-vercel
CLOUDFLARE_API_TOKEN=your-cloudflare-token              # 08-provider-cloudflare
CLOUDFLARE_SANDBOX_WORKER_URL=https://your-worker.url   # 08-provider-cloudflare
# Docker: no API key needed, just a running Docker daemon  # 09-provider-docker
